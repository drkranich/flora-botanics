{
  // Worker do SITE (storefront). Usa o MESMO nome do worker atual
  // ("flora-botanics"): o deploy substitui o site estático antigo
  // pelo Next.js dinâmico ligado ao Supabase — mesma URL.
  "name": "flora-botanics",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
